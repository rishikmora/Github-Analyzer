# ─────────────────────────────────────────────────────────────
#  DevIQ — Environment Variables
#  Copy this file:  cp .env.example .env
#  Fill in ANY keys you have. All are optional except at least
#  one AI key. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────

# ── AI Keys — add any/all you have ───────────────────────────

# Anthropic Claude — https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI GPT-4o — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (Llama 3.3 70B, free tier) — https://console.groq.com/keys
GROQ_API_KEY=

# ── Data Enrichment ───────────────────────────────────────────

# GitHub Token — https://github.com/settings/tokens (no scopes needed)
# Raises rate limit from 60 → 5000 req/hr, enables GraphQL enrichment
GITHUB_TOKEN=

# Serper Web Search — https://serper.dev (2500 free searches)
# Powers job market data and trending tech detection
SERPER_API_KEY=

# ── Server Config ─────────────────────────────────────────────

# Port for the proxy server (default: 3001)
PORT=3001

# Restrict CORS to your domain in production (default: * = all origins)
# ALLOWED_ORIGIN=https://yourdomain.com
